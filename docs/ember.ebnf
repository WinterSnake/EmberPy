program: expression*;
expression: 'DEBUG__PRINTU__' '(' expression_add_or_sub ')' ';';
expression_add_or_sub: expression_mul_or_div_or_mod (('+' | '-') expression_mul_or_div_or_mod)*;
expression_mul_or_div_or_mod: DIGIT (('*' | '/' | '%') DIGIT)*;

DIGIT: '-'? \d+;
IDENTIFIER: [a-zA-Z_][a-zA-Z0-9_]*;
